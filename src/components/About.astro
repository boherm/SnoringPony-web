---
import { Picture } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '@i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import Logo from '@assets/logo.png';
import PaypalLogo from '@assets/paypal.svg';
import PatreonLogo from '@assets/patreon.svg';
import GithubLogo from '@assets/github.svg';
---
<section id="about">
    <div class="section-wrapper">
        <div class="container mx-auto mb-15">

            <div class="flex flex-col md:flex-row items-center md:items-start gap-8">
                <div class="col w-1/2 md:w-1/3">
                    <div class="flex flex-col gap-4 items-center">
                        <Picture src={Logo} alt="Logo" class="mx-auto drop-shadow-xl drop-shadow-neutral-950/40" />
                        <p class="text-neutral-400 italic text-sm">"Hiiiih, prrrfff !"<br/>Indy</p>
                    </div>
                </div>
                <div class="col md:w-2/3 flex flex-col gap-8">
                    <h1 class="bold text-4xl text-center">{t('about.title')}</h1>
                    <div class="flex flex-col gap-2">
                        <h2 class="text-2xl">{t('about.block1.title')}</h2>
                        <p class="text-neutral-300/80 text-justify"><Fragment set:html={t('about.block1.text')} /></p>
                    </div>
                    <div class="flex flex-col gap-2">
                        <h2 class="text-2xl">{t('about.block2.title')}</h2>
                        <p class="text-neutral-300/80 text-justify"><Fragment set:html={t('about.block2.text1')} /></p>
                        <p class="text-neutral-300/80 text-justify"><Fragment set:html={t('about.block2.text2')} /></p>
                        <p class="text-neutral-300/80 text-justify"><Fragment set:html={t('about.block2.text3')} /></p>
                        <div class="flex flex-col lg:flex-row justify-center items-center gap-3 mt-3">
                            <a href="https://www.paypal.me/boerms" target="_blank" class="btn btn-secondary">
                                <span class="inline-flex items-center gap-2">
                                    <PaypalLogo width={20} height={20} />
                                    <span>{t('downloads.modal.donatePaypal')}</span>
                                </span>
                            </a>
                            <a href="https://patreon.com/boherm" target="_blank" class="btn btn-secondary">
                                <span class="inline-flex items-center gap-2">
                                    <PatreonLogo width={20} height={20} />
                                    <span>{t('downloads.modal.donatePatreon')}</span>
                                </span>
                            </a>
                            <a href="https://github.com/sponsors/boherm" target="_blank" class="btn btn-secondary">
                                <span class="inline-flex items-center gap-2">
                                    <GithubLogo width={20} height={20} />
                                    <span>{t('downloads.modal.donateGithub')}</span>
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{ !version && type != "dev" &&
<div class="container mx-auto">
    <div class="flex gap-1">
        <div class="flex flex-col items-center bg-neutral-500/10 p-6 rounded-lg w-full text-center">
            { type == 'stable' && <h2 class="bold text-2xl my-4">{t('downloads.noStableVersionAvailable')}</h2>}
            { type == 'beta' && <h2 class="bold text-2xl my-4">{t('downloads.noBetaVersionAvailable')}</h2>}

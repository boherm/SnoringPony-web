---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import ArrowLeft from '@assets/arrow-left.svg';
import ArrowRight from '@assets/arrow-right.svg';
---
<section id="features">
    <div class="section-wrapper">
        <div class="container mx-auto mb-20">
            <div class="flex flex-col gap-10">
                <h1 class="bold text-4xl text-center">{t('features.title')}</h1>
                <p class="text-lg md:text-xl md:text-center">{t('features.description')}</p>
            </div>
            <div class="flex items-start gap-6 mt-10">

                <div class="flex flex-col items-center bg-neutral-500/10 p-6 rounded-lg">
                    <h2 class="text-lg font-bold">Titre</h2>
                    <ul class="flex flex-col gap-2 mt-3 list-disc list-inside">
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                        <li>Lorem nobis dolorem ut sed quisquam</li>
                    </ul>
                </div>

                <div class="flex flex-col justify-center items-center">
                    <div class="relative"
                        x-data="{
                        activeImage: 1,
                        images: [ 'https://picsum.photos/1024/768?1', 'https://picsum.photos/1024/768?2', 'https://picsum.photos/1024/768?3']
                        }">

                        <template x-for="(image,index) in images" :key="index">
                            <div x-show="activeImage === index + 1"
                                x-transition:enter="transition-all ease-in-out duration-1000"
                                x-transition:enter-start="opacity-0 transform"
                                x-transition:enter-end="opacity-100 transform"
                                >
                                <img x-bind:src="image" class="max-w-full shadow-xl shadow-neutral-900/25 rounded-lg overflow-hidden">
                                <p x-text="activeImage + ' / ' + images.length" class="text-center text-sm mt-2 text-neutral-200/60"></p>
                            </div>
                        </template>

                        <div class="absolute top-1/2 left-2 translate-y-[-50%]">
                            <button class="cursor-pointer text-lg md:text-2xl lg:text-5xl text-white"
                                x-on:click="activeImage = activeImage === images.length ? 1 : activeImage + 1">
                                <ArrowLeft width={20} height={20} class="drop-shadow-md drop-shadow-neutral-900" />
                            </button>
                        </div>

                        <div class="absolute top-1/2 right-2 translate-y-[-50%]">
                            <button class="cursor-pointer text-lg md:text-2xl lg:text-5xl text-white"
                                x-on:click="activeImage = activeImage === images.length ? 1 : activeImage + 1">
                                <ArrowRight width={20} height={20} class="drop-shadow-md drop-shadow-neutral-900" />
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
